generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id           String        @id // Clerk userId
  name         String
  email        String
  phone        String?
  imageUrl     String?
  appointments Appointment[]
}

model Specialty {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String
  doctorCount Int
  doctors     Doctor[]
}

model Doctor {
  id             String        @id // store Clerk userId
  name           String
  title          String
  specialtyId    String
  specialty      Specialty     @relation(fields: [specialtyId], references: [id])
  location       String
  imageUrl       String
  bio            String
  appointments   Appointment[]
  education      Json?
  certifications Json?
  languages      Json?
}

model Appointment {
  id        Int      @id @default(autoincrement())
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  String
  userId    String
  date      DateTime
  time      String
  Patient   Patient? @relation(fields: [patientId], references: [id])
  patientId String?
}

model AITool {
  id          String @id @default(cuid())
  title       String
  description String
  category    String
  imageUrl    String
}
